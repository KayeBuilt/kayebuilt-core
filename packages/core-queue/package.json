{
  "name": "@kayebuilt/core-queue",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --exclude '**/node_modules/**' --exclude '**/dist/**' --exclude '**/*.integration.test.ts'",
    "test:integration": "vitest run integration.test.ts",
    "lint": "biome check .",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "bullmq": "^5.34.6",
    "ioredis": "5.10.1"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "testcontainers": "^12.0.4",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  }
}
